* text=auto

# Source and config files should stay LF across platforms.
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.svg text eol=lf
*.java text eol=lf
*.kt text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.plist text eol=lf
*.pbxproj text eol=lf
